# Astra — environment variables
# Copy this file to .env and fill in the keys you need.
# You only need one LLM provider key to run Astra.
# .env is gitignored — never commit your real keys.

# ── LLM providers ────────────────────────────────────────────────────────────

# Groq (fast, free tier available — good default for getting started)
# GROQ_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=

# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=

# ── OpenAI-compatible endpoints (provider: "other") ───────────────────────────
# Set a base URL in your astra config instead of here. API key goes below
# if the endpoint requires one.
# CUSTOM_LLM_API_KEY=

# ── Telemetry enrichment (optional) ──────────────────────────────────────────

# Langfuse — pulls production traces to ground attack prompts
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Netra
# NETRA_API_KEY=

# ── MCP server authentication (optional) ─────────────────────────────────────
# If your MCP server requires a bearer token, set it here and reference the
# variable name in your astra config under mcp.server.headers:
#   "headers": { "Authorization": "Bearer ${MCP_AUTH_TOKEN}" }
# MCP_AUTH_TOKEN=
