{
  "manifest_version": 3,
  "name": "Astra UI Injector (dev)",
  "version": "0.0.1",
  "description": "Dev helper: find a chat input on the current page and send a 'hi' message.",
  "action": {
    "default_title": "Astra Injector",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  }
}
