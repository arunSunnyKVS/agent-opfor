{
  "name": "opfor",
  "version": "0.1.0",
  "description": "Opfor CLI — security testing for AI agents and MCP servers (opfor setup|generate|execute)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "opfor": "./dist/index.js"
  },
  "files": [
    "dist/",
    "data/"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run build:ui && tsc -p tsconfig.json",
    "build:ui": "cd ui && npm install && npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx/esm --test tests/*.test.ts"
  },
  "dependencies": {
    "@opfor/core": "*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.165",
    "@anthropic-ai/sdk": "^0.100.1",
    "@ai-sdk/anthropic": "^2.0.77",
    "@ai-sdk/azure": "^3.0.65",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^2.0.70",
    "@ai-sdk/openai": "^2.0.103",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@inquirer/prompts": "^8.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.0",
    "commander": "^14.0.1",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
