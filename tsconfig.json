{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/mcp/**/*.ts",
    "src/mcp/**/*.d.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["src/agent"]
}
