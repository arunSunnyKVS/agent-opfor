# Provider to use: openai | anthropic | groq | google
# PROVIDER=

# Optional — override the default model for the chosen provider
# Defaults: openai=gpt-4o-mini, anthropic=claude-3-5-haiku-20241022, groq=llama-3.3-70b-versatile, google=gemini-2.0-flash
# MODEL=

# Supply the key for your chosen provider (others can be left blank)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# GOOGLE_API_KEY=

# Optional — custom OpenAI-compatible base URL (Ollama, OpenRouter, Azure, etc.)
# BASE_URL=
