{
  "name": "opfor-monorepo",
  "version": "0.1.0",
  "description": "Opfor — security testing for AI agents and MCP servers (workspace root)",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "core",
    "runners/cli",
    "runners/mcp",
    "runners/extension",
    "tests/e2e/agents/vanilla-chat",
    "tests/e2e/agents/customer-support"
  ],
  "files": [
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -b core runners/cli runners/mcp && npm run extension:catalog && npm run build:core --workspace=@opfor/extension",
    "test": "npm test --workspace=core",
    "typecheck": "tsc -b core runners/cli runners/mcp",
    "extension:catalog": "npm run build:catalog --workspace=@opfor/extension",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:skills": "tsx scripts/validate-skills.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2",
    "zod": "^3.25.76"
  }
}
