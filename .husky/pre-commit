#!/usr/bin/env sh
npm run typecheck
npm run lint
npm run format:check
npm run build:catalog
npm run extension:catalog
git add skills/mcp-redteaming/opfor-setup/catalog.json skills/agent-redteaming/opfor-setup/catalog.json runners/extension/catalog.json
npm run validate:skills

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "Error: gitleaks is required but not installed."
  echo "Install: https://github.com/gitleaks/gitleaks#installing"
  exit 1
fi
gitleaks protect --staged --redact
